    <var id="vSeasonId" datatype="CHAR" description="key to select default season in management (M)">default</var>
    <var id="vSoilType" datatype="CHAR" description="key to select default values for soil parameters (S)">default</var>
    <var id="vCropName" datatype="CHAR" description="key to select default values for cropw parameters (C)">default</var>
    <var id="startdate" datatype="DATE" description="taken from (B)">31.03.1987</var>
    <var id="enddate" datatype="DATE" description="runs until end of year">31.12.1987</var>
    <var id="vCO" datatype="DOUBLE" unit="http://www.wurvoc.org/vocabularies/om-1.8/parts_per_million" description="value taken from (B)">370</var>
    <var id="vIOPT" datatype="INT" description="switch: water and NPK-limitation on, value taken from (B), line 9">4</var>
    <var id="vIRRI" datatype="INT" description="switch: no irrigation, value taken from (B), line 9">0</var>
    <var id="vIDEM" datatype="INT" unit="http://www.wurvoc.org/vocabularies/om-1.8/one" description="day of emergence, value taken from (B), line 9">90</var>
  </variables>
  
