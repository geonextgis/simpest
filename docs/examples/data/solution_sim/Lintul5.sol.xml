        <res id="SolarConstant" datatype="DOUBLE" unit="http://www.wurvoc.org/vocabularies/joule_per_square_metre_second-time" />
        <res id="SINLD" datatype="DOUBLE" unit="http://www.wurvoc.org/vocabularies/om-1.8/one" />
        <res id="COSLD" datatype="DOUBLE" unit="http://www.wurvoc.org/vocabularies/om-1.8/one" />
        <res id="DSINB" datatype="DOUBLE" unit="http://www.wurvoc.org/vocabularies/om-1.8/second-time_per_day" />
        <res id="DSINBE" datatype="DOUBLE" unit="http://www.wurvoc.org/vocabularies/om-1.8/second-time_per_day" />
      </header>
      <input id="SunInclinationField">SunInclination</input>
      <input id="LatitudeField">Latitude</input>
      <input id="IdField">SeasonId</input>
    </transform>
  </resources>
