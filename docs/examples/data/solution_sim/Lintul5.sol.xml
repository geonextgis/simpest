        <mgm id="DoSow" datatype="BOOLEAN" default="false" rule="true" />
      </action>
      <action rule="${Phenology.IsMaturity}">
        <description title="Determine harvest day of year">Harvest occurs when the development stage is bigger than 2.</description>
        <mgm id="DoHarvest" datatype="BOOLEAN" default="false" rule="true" />
      </action>
      <action rule="${CURRENT.DOY}==${vIDEM} || (${DefaultManagement.WithCrop} &amp;&amp; !${Phenology.IsMaturity})">
