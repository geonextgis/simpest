      <header>
        <res id="CURRENTDATE" datatype="DATE" key="CURRENT.DATE" />
        <res id="Irradiation" unit="http://www.wurvoc.org/vocabularies/om-1.8/joule_per_square_metre_day" datatype="DOUBLE" />
        <res id="TMin" unit="http://www.wurvoc.org/vocabularies/om-1.8/degree_Celsius" datatype="DOUBLE" />
        <res id="TMax" unit="http://www.wurvoc.org/vocabularies/om-1.8/degree_Celsius" datatype="DOUBLE" />
        <res id="WindSpeed" unit="http://www.wurvoc.org/vocabularies/om-1.8/metre_per_second-time" datatype="DOUBLE" />
        <res id="VapourPressure" unit="http://www.wurvoc.org/vocabularies/om-1.8/hectopascal" datatype="DOUBLE" />
        <res id="Precipitation" unit="http://www.wurvoc.org/vocabularies/om-1.8/millimetre" datatype="DOUBLE" />
      </header>
      <input id="statement">SELECT 
					   				CURRENTDATE, 
					   				Irradiation*1000 AS Irradiation,
					   				TMin,
					   				TMax,
					   				VapourPressure*10 AS VapourPressure,
					   				WindSpeed,
					   				Precipitation AS Precipitation
					   			  FROM weather</input>
    </transform>
    <transform id="at" frequence="DAILY" resource="management" class="net.simplace.sim.transformers.AstronomicParametersTransformer">
      <header>
        <res id="DOY" datatype="INT" key="CURRENT.DOY" />
        <res id="SeasonId" datatype="CHAR" key="vSeasonId" />
        <res id="DayLength" datatype="DOUBLE" unit="http://www.wurvoc.org/vocabularies/om-1.8/hour" />
